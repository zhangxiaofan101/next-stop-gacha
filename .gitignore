.DS_Store
*.pyc
__pycache__/
dist/
node_modules/
.wrangler/

# 插画轨道：raw 为文生图候选原图（体积大、可再生），只留本地不进 git
assets/illustrations/raw/*
!assets/illustrations/raw/.gitkeep

# M39 throwaway 质感样稿（引用 raw/ 本地图，不合入主线）
m39-sample*.html

# M46 字体管线：源字体体积大、可从公开地址重新下载（见 fonts/README.md），只留本地不进 git
fonts/source/*
!fonts/source/.gitkeep
